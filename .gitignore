# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd

# Virtual environments
.venv/
venv/
.env/
.conda/

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Jupyter
.ipynb_checkpoints

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Env files
.env
*.env
.env.*

# Logs and temp files
*.log
test_import.txt

# Generated run outputs (plots, pass JSON results)
outputs/*.png
outputs/*.json
outputs/*.html

# TLE cache (fetched live data)
data/tle_cache/

# Collected historical position sequences (large, regenerated from Space-Track)
data/collected/*.csv
data/collected/*.npy
data/collected/*.json

# Colab download artifacts that land in notebooks/
notebooks/*.zip
notebooks/*.npy
notebooks/*.csv
notebooks/*.pt
notebooks/*.pkl
notebooks/*.png
notebooks/*.html

# Experiment artifacts (model checkpoints, logs — keep only final models in models/)
experiments/*/checkpoints/
experiments/**/runs/

# Streamlit cache
.streamlit/
